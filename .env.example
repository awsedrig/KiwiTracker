# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=kiwitracker

# Connection Strings
CONNECTION_STRING=Host=postgres;Port=5432;Database=kiwitracker;Username=postgres;Password=your_secure_password_here
REDIS_CONNECTION=redis:6379

# JWT
JWT_KEY=your_jwt_secret_key_at_least_32_characters_long
JWT_ISSUER=KiwiTrackerAPI
JWT_AUDIENCE=KiwiTrackerClient

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
